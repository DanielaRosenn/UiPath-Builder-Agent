# UiPath Claude Code - Environment Configuration
#
# Copy to `.env` in the directory you run `uipath-claude chat` from; the CLI loads
# it automatically. Variables starting with UIPATH_ from this file override the
# same names from the shell / Windows environment so project settings win.
#
# Replace placeholders. Values come from Automation Cloud:
# Tenant name (UIPATH_TENANT_NAME) is the logical tenant for auth/API — often
# "DefaultTenant", "Test", or a name from Admin; it is NOT the same as
# UIPATH_DEFAULT_FOLDER (Orchestrator folder for packages: Dev/Prod/Test).

# Orchestrator base URL (replace YOUR_ACCOUNT with your cloud account slug)
UIPATH_ORCHESTRATOR_URL=https://cloud.uipath.com/YOUR_ACCOUNT/Test/orchestrator_

# Cloud tenant / service name used by `uipath auth --cloud --tenant ...`
UIPATH_TENANT_NAME=Test

# Target folder in Orchestrator for deploy (Dev, Prod, Test, Shared, ...)
UIPATH_DEFAULT_FOLDER=Test

# Optional: Account Name (for multi-account setups)
# UIPATH_ACCOUNT_NAME=

# Chat Configuration
# Enable/disable streaming responses (default: 1)
UIPATH_CHAT_STREAM=1

# Enable/disable debug mode (default: 1)
UIPATH_DEBUG_AGENT=1

# Verbose tool args in the agentic console (default: 1). Set to 0 for quieter output.
# UIPATH_DEBUG_VERBOSE=0

# Custom output directory for generated workflows
# UIPATH_CHAT_OUTPUT_DIR=C:\MyProjects\Generated

# Process Tracking (default: enabled)
# Set to 0 to disable automatic cleanup of test-spawned Studio processes
UIPATH_TRACK_PROCESSES=1

# ---------------------------------------------------------------------------
# Confluence publishing (scripts/publish_confluence.py)
#
# Authenticates through UiPath Integration Service. Atlassian credentials
# live inside UiPath (Automation Cloud -> Integration Service -> Connections),
# NOT here. Python only needs UiPath credentials + the IS connection ID.
#
# One-time setup:
#   1. In Automation Cloud -> Integration Service -> Connections, add an
#      "Atlassian Confluence" connection authenticated as the Cato tenant.
#      Name it AtlassianConfluence-Cato.
#   2. Open the connection and copy its Connection ID into
#      UIPATH_IS_CONFLUENCE_CONNECTION_ID below.
#   3. Pick an auth mode: UIPATH_PAT (simplest) or client-credentials.
# ---------------------------------------------------------------------------

# UiPath Cloud base URL (default works for most tenants)
UIPATH_CLOUD_BASE_URL=https://cloud.uipath.com

# Account slug (from the Automation Cloud URL: cloud.uipath.com/<account>/...)
UIPATH_ACCOUNT_NAME=catonetworks

# Integration Service connection ID for Atlassian Confluence (Cato tenant).
# Reuse the same value that other Cato projects store as UIPATH_ATLASSIAN_CONNECTION_ID.
UIPATH_ATLASSIAN_CONNECTION_ID=af2c10ac-fe3e-472b-bc11-60dd44df92fb

# Optional override for the IS proxy path. Default:
#   {account}/{tenant}/connectors_/api/v1/connections/{connection_id}/execute
# UIPATH_IS_PROXY_PATH=

# Auth mode A (simplest): Personal Access Token from Automation Cloud
# UIPATH_PAT=

# Auth mode B: OAuth2 client-credentials (external application registered in
# Automation Cloud -> Admin -> External Applications)
# UIPATH_CLIENT_ID=
# UIPATH_CLIENT_SECRET=
# UIPATH_OAUTH_SCOPE=OR.Execution IntegrationService

# Confluence target space and (optional) parent page
ATLASSIAN_SITE=catonetworks.atlassian.net
CONFLUENCE_SPACE_KEY=RPA
# CONFLUENCE_PARENT_PAGE_ID=
