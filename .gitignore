# Cursor local IDE data
# Ignore everything under .cursor/ *except* the files we explicitly share with
# the team (hooks). Git will only honor re-inclusion rules when the parent
# directory is not itself ignored, so we ignore contents with /* instead of
# ignoring the directory with a trailing slash.
.cursor/*
!.cursor/hooks.json
!.cursor/hooks
!.cursor/rules
!.cursor/rules/**
!.cursor/skills
!.cursor/skills/**
!.cursor/mcp.json.example
.cursor/hooks/state/
.cursor/plans/

# Local runtime / tooling data
# Legacy cache dirs accidentally created inside committed library content
data/library/**/_cache/
.uipath-claude/
.uipath/*
!.uipath/skills-approved.sha
.skills_refresh_at
.skills_session_refresh

# Ad-hoc debug session logs
debug-*.log

# Scratch / generated local projects
HelloWorld/

# Ephemeral chat / CLI scratch at repo root
/chat_input.txt
/chat_output.log
/chat_run.log
/banner-check.txt
/.assistant-choice

# Invoice demo: regenerated by uipcli / Studio (do not commit)
InvoiceIntake_Demo/analyze.json
InvoiceIntake_Demo/BUILD_LOG.md
InvoiceIntake_Demo/BUILD_SUMMARY.md

# Packaged rule bundles left from local experiments
extensions/*.zip

# Evaluation run outputs
evaluation_results*.json
docs/evaluations/results/
!docs/evaluations/results/run_20260417_library/
!docs/evaluations/results/run_20260417_library/**

# Excel temporary lock files
~$*.xlsx

# Sample UiPath test project: keep only tracked project.json; never commit full projects
tests/fixtures/sample_project/*
!tests/fixtures/sample_project/project.json

# UiPath Studio build artifacts (per-project caches, settings, packages)
**/.local/
**/.project/
**/.settings/
**/.tmh/
**/.entities/
**/.objects/
*.nupkg

# Locally scaffolded example projects (build artifacts, not source)
examples/InvoiceQueueProcessor/

